{
  "name": "@author/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "start": "electron .",
    "app": "pnpm build && pnpm start",
    "package": "pnpm build && electron-builder --win --x64",
    "package:portable": "pnpm build && electron-builder --win portable --x64",
    "typecheck": "tsc -b --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "build": {
    "appId": "com.alexanderson.authorcontrol",
    "productName": "Author Control Center",
    "files": [
      "electron/dist/**",
      "dist/**",
      "package.json",
      "!**/*.map"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Author Control"
    }
  },
  "dependencies": {
    "@author/api-client": "workspace:*",
    "bcryptjs": "^2.4.3",
    "electron-store": "^10.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0",
    "vite": "^5.4.10"
  }
}
