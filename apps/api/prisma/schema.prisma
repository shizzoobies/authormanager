// Phase 1 starter schema. Expand in Phase 2 when member gating lands.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PenName {
  ALEXI_HART
  ALEXANDRA_KNIGHT
}

model Member {
  id           String   @id @default(cuid())
  email        String
  penName      PenName
  confirmedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([email, penName])
}

model Release {
  id          String   @id @default(cuid())
  penName     PenName
  title       String
  slug        String
  releaseDate DateTime
  blurb       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([penName, slug])
}
