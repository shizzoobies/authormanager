// Phase 2 schema: subscribers, confirmation tokens, and members.
//
// A Subscriber is the local mirror of a Listmonk subscriber for a single
// pen-name list. Confirmation happens through our own JWT-link flow so we
// can issue a session cookie at the same moment we mark the subscriber confirmed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PenName {
  ALEXI_HART
  ALEXANDRA_KNIGHT
}

model Subscriber {
  id                   String    @id @default(cuid())
  email                String
  penName              PenName
  listmonkSubscriberId Int?
  confirmedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([email, penName])
  @@index([penName])
}

model Release {
  id          String   @id @default(cuid())
  penName     PenName
  title       String
  slug        String
  releaseDate DateTime
  blurb       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([penName, slug])
}
